<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Wanderlust - Sejal's Cultural Odyssey</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&family=Playfair+Display:ital,wght@0,700;1,700&display=swap');
        
        body {
            font-family: 'Inter', sans-serif;
            scroll-behavior: smooth;
        }
        
        h1, h2, h3, .serif {
            font-family: 'Playfair Display', serif;
        }

        /* Subtle Indian Pattern Overlay */
        .cultural-bg {
            background-color: #fffaf5;
            background-image: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23f97316' fill-opacity='0.05'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4v-4H4v4H0v2h4v4h2v-4h4v-2H6zM36 4v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
        }

        .blog-card img {
            transition: transform 0.7s ease-out;
            filter: brightness(1.05) contrast(1.02);
        }

        .blog-card:hover img {
            transform: scale(1.08);
        }

        .glass {
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
        }

        .saffron-gradient {
            background: linear-gradient(135deg, #f97316 0%, #ea580c 100%);
        }
    </style>
</head>
<body class="cultural-bg text-stone-900">

    <!-- Navigation -->
    <nav class="fixed w-full z-50 glass border-b border-orange-100">
        <div class="max-w-6xl mx-auto px-4 h-16 flex items-center justify-between">
            <a href="#" class="text-2xl font-bold tracking-tighter serif text-orange-800">SEJAL'S ODYSSEY</a>
            
            <!-- Desktop Menu -->
            <div class="hidden md:flex space-x-8 font-medium text-xs uppercase tracking-[0.2em]">
                <a href="#home" class="hover:text-orange-600 transition">Heritage</a>
                <a href="#stories" class="hover:text-orange-600 transition">Stories</a>
                <a href="#about" class="hover:text-orange-600 transition">The Traveler</a>
                <a href="#contact" class="hover:text-orange-600 transition">Connect</a>
            </div>

            <button class="md:hidden text-orange-800" onclick="toggleMenu()">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7" />
                </svg>
            </button>
        </div>
        
        <!-- Mobile Dropdown -->
        <div id="mobile-menu" class="hidden md:hidden bg-white border-b border-orange-100 flex flex-col p-6 space-y-4 text-center">
            <a href="#home" onclick="toggleMenu()" class="text-orange-800 font-bold">Home</a>
            <a href="#stories" onclick="toggleMenu()">Stories</a>
            <a href="#about" onclick="toggleMenu()">About</a>
            <a href="#contact" onclick="toggleMenu()">Contact</a>
        </div>
    </nav>

    <!-- Hero Section -->
    <header id="home" class="relative h-screen flex items-center justify-center overflow-hidden">
        <div class="absolute inset-0 z-0">
            <div class="w-full h-full bg-stone-950 flex items-center justify-center">
                <!-- Hero image opacity increased for better visibility -->
                <div class="absolute inset-0 opacity-85 bg-[url('https://images.unsplash.com/photo-1477587458883-47145ed94245?q=80&w=2070')] bg-cover bg-center"></div>
                <div class="absolute inset-0 bg-gradient-to-b from-stone-900/40 via-transparent to-stone-900/80"></div>
            </div>
        </div>
        
        <div class="relative z-10 text-center text-white px-4">
            <span class="inline-block px-4 py-1 border border-orange-400/70 rounded-full text-[10px] uppercase tracking-[0.4em] mb-6 backdrop-blur-md bg-stone-900/20">Culture &bull; Heritage &bull; Soul</span>
            <h1 class="text-6xl md:text-9xl mb-8 leading-tight italic drop-shadow-2xl">Incredible Bharat</h1>
            <p class="text-lg md:text-xl font-medium max-w-2xl mx-auto mb-10 text-white drop-shadow-md">Exploring the deep-rooted traditions and majestic landscapes of my homeland.</p>
            <a href="#stories" class="inline-block saffron-gradient px-10 py-4 shadow-xl hover:scale-105 transition-all font-bold uppercase text-xs tracking-widest rounded-full">
                Begin The Journey
            </a>
        </div>
    </header>

    <!-- Blog Posts Section -->
    <section id="stories" class="py-24 px-4 max-w-6xl mx-auto">
        <div class="text-center mb-20">
            <p class="text-orange-600 font-bold tracking-widest text-xs uppercase mb-2">Curated Experiences</p>
            <h2 class="text-5xl serif">Cultural Chapters</h2>
            <div class="h-1 w-12 bg-orange-600 mx-auto mt-6"></div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-16">
            <!-- Story 1: Spiritual -->
            <article class="blog-card group">
                <div class="overflow-hidden rounded-2xl mb-8 shadow-2xl aspect-[3/4] relative bg-stone-200">
                    <img src="https://images.unsplash.com/photo-1561361513-2d000a50f0dc?q=80&w=1000" 
                         alt="Varanasi Aarti" 
                         class="object-cover w-full h-full">
                    <!-- Reduced gradient overlay to keep image visible -->
                    <div class="absolute inset-0 bg-gradient-to-t from-orange-900/40 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
                </div>
                <div class="px-2">
                    <span class="text-orange-600 text-[10px] font-black uppercase tracking-[0.2em]">Spiritual &bull; Varanasi</span>
                    <h3 class="text-3xl mt-3 mb-4 serif group-hover:text-orange-700 transition">Soul of the Ganges</h3>
                    <p class="text-stone-600 leading-relaxed mb-6 italic">
                        The rhythmic chanting of priests and the glow of thousand lamps—Varanasi isn't just a city; it's a feeling of eternal peace.
                    </p>
                    <a href="#" class="text-orange-900 font-bold text-xs uppercase tracking-widest flex items-center gap-2 group">
                        Enter Chapter <span class="group-hover:translate-x-2 transition-transform">→</span>
                    </a>
                </div>
            </article>

            <!-- Story 2: Architecture/Heritage -->
            <article class="blog-card group">
                <div class="overflow-hidden rounded-2xl mb-8 shadow-2xl aspect-[3/4] relative bg-stone-200">
                    <img src="https://images.unsplash.com/photo-1524492412937-b28074a5d7da?q=80&w=1000" 
                         alt="Agra Heritage" 
                         class="object-cover w-full h-full">
                    <div class="absolute inset-0 bg-gradient-to-t from-orange-900/40 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
                </div>
                <div class="px-2">
                    <span class="text-orange-600 text-[10px] font-black uppercase tracking-[0.2em]">Architecture &bull; Agra</span>
                    <h3 class="text-3xl mt-3 mb-4 serif group-hover:text-orange-700 transition">Marble Whispers</h3>
                    <p class="text-stone-600 leading-relaxed mb-6 italic">
                        Standing before the Taj Mahal at dawn, you realize that some monuments aren't built of stone, but of pure, undying emotion.
                    </p>
                    <a href="#" class="text-orange-900 font-bold text-xs uppercase tracking-widest flex items-center gap-2 group">
                        Enter Chapter <span class="group-hover:translate-x-2 transition-transform">→</span>
                    </a>
                </div>
            </article>

            <!-- Story 3: Ancient Ruins -->
            <article class="blog-card group">
                <div class="overflow-hidden rounded-2xl mb-8 shadow-2xl aspect-[3/4] relative bg-stone-200">
                    <img src="https://images.unsplash.com/photo-1590050752117-23a9d7fc2173?q=80&w=1000" 
                         alt="Hampi Ruins" 
                         class="object-cover w-full h-full">
                    <div class="absolute inset-0 bg-gradient-to-t from-orange-900/40 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
                </div>
                <div class="px-2">
                    <span class="text-orange-600 text-[10px] font-black uppercase tracking-[0.2em]">Ancient &bull; Hampi</span>
                    <h3 class="text-3xl mt-3 mb-4 serif group-hover:text-orange-700 transition">Echoes of Vijayanagara</h3>
                    <p class="text-stone-600 leading-relaxed mb-4 italic line-clamp-3">
                        Walking through the boulder-strewn landscape of Hampi, where every stone tells a story of a lost empire and divine craftsmanship.
                    </p>
                    <a href="#" class="text-orange-900 font-bold text-xs uppercase tracking-widest flex items-center gap-2 group">
                        Enter Chapter <span class="group-hover:translate-x-2 transition-transform">→</span>
                    </a>
                </div>
            </article>
        </div>
    </section>

    <!-- About Section -->
    <section id="about" class="bg-stone-900 text-stone-100 py-32 px-4 relative overflow-hidden">
        <!-- Decorative Circle -->
        <div class="absolute top-0 right-0 w-96 h-96 bg-orange-600/10 rounded-full -mr-48 -mt-48 blur-3xl"></div>
        
        <div class="max-w-4xl mx-auto flex flex-col md:flex-row items-center gap-16 relative z-10">
            <div class="w-64 h-80 rounded-3xl overflow-hidden shadow-2xl flex-shrink-0 border-8 border-stone-800 rotate-2 transition-transform hover:rotate-0 duration-500">
                <img src="https://images.unsplash.com/photo-1526481280693-3bfa7561eca0?q=80&w=1000" 
                     alt="Sejal the Traveler" 
                     class="w-full h-full object-cover brightness-110">
            </div>
            <div>
                <p class="text-orange-500 font-bold uppercase tracking-widest text-xs mb-4">Meet Your Guide</p>
                <h2 class="text-5xl serif mb-6 italic">Namaste, I'm Sejal.</h2>
                <p class="text-stone-400 text-lg leading-relaxed mb-8">
                    My heart beats for the hidden alleys of Rajasthan and the silent peaks of the Himalayas. I believe India is not just a destination, but an experience that demands to be felt slowly. Through this blog, I bring you the textures, tastes, and tales of my beloved Bharat.
                </p>
                <div class="flex space-x-8 items-center">
                    <a href="#" class="text-white hover:text-orange-500 transition-all flex items-center gap-2">
                        <span class="text-sm font-bold tracking-widest">INSTAGRAM</span>
                    </a>
                    <a href="#" class="text-white hover:text-orange-500 transition-all flex items-center gap-2">
                        <span class="text-sm font-bold tracking-widest">YOUTUBE</span>
                    </a>
                </div>
            </div>
        </div>
    </section>

    <!-- Footer / Newsletter -->
    <footer id="contact" class="bg-white border-t border-orange-100 py-24 px-4 text-center">
        <div class="max-w-2xl mx-auto">
            <h2 class="text-4xl serif text-orange-900 mb-4">Stay in the Loop</h2>
            <p class="text-stone-500 mb-10">Get my monthly travel itinerary and cultural insights directly in your inbox.</p>
            
            <form id="subscribeForm" class="flex flex-col sm:flex-row gap-4 mb-16 p-2 bg-stone-50 rounded-full border border-orange-100">
                <input type="email" placeholder="Your email address" class="flex-1 bg-transparent px-6 py-3 outline-none text-stone-800">
                <button type="button" onclick="showMsg()" class="saffron-gradient text-white px-10 py-3 font-bold uppercase text-xs tracking-widest rounded-full hover:shadow-lg transition">
                    Subscribe
                </button>
            </form>

            <div id="msgBox" class="hidden bg-orange-50 text-orange-800 p-4 mb-8 rounded-xl border border-orange-200">
                Welcome to the family! Looking forward to sharing stories with you.
            </div>

            <div class="flex justify-center space-x-12 mb-12">
                <div class="text-center">
                    <p class="text-2xl serif text-orange-900">23+</p>
                    <p class="text-[10px] uppercase tracking-widest text-stone-400">States Visited</p>
                </div>
                <div class="text-center border-x border-stone-200 px-12">
                    <p class="text-2xl serif text-orange-900">150+</p>
                    <p class="text-[10px] uppercase tracking-widest text-stone-400">Stories Shared</p>
                </div>
                <div class="text-center">
                    <p class="text-2xl serif text-orange-900">5k</p>
                    <p class="text-[10px] uppercase tracking-widest text-stone-400">Fellow Explorers</p>
                </div>
            </div>

            <p class="text-[10px] text-stone-400 uppercase tracking-[0.3em]">&copy; 2024 SEJAL'S ODYSSEY &bull; HANDCRAFTED IN INDIA</p>
        </div>
    </footer>

    <script>
        function toggleMenu() {
            const menu = document.getElementById('mobile-menu');
            menu.classList.toggle('hidden');
        }

        function showMsg() {
            const box = document.getElementById('msgBox');
            box.classList.remove('hidden');
            setTimeout(() => {
                box.classList.add('hidden');
            }, 5000);
        }

        const observerOptions = { threshold: 0.05 };
        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.classList.add('opacity-100');
                    entry.target.classList.remove('translate-y-10');
                }
            });
        }, observerOptions);

        document.querySelectorAll('article').forEach(el => {
            // Increased initial opacity from 0 to 0.2 to ensure they are visible even before fully fading in
            el.classList.add('opacity-20', 'translate-y-10', 'transition', 'duration-1000');
            observer.observe(el);
        });
    </script>
</body>
</html>