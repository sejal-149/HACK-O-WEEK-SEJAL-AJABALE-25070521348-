<!DOCTYPE html>
<html>
<head>
    <title>My Photo Gallery</title>
    <style>
        /* Basic Styles */
        body {
            font-family: Arial, sans-serif;
            background-color: #f0f0f0;
            text-align: center;
            margin: 0;
            padding: 20px;
        }

        h1 {
            color: #333;
        }

        /* The Gallery Grid */
        .gallery {
            display: flex;
            flex-wrap: wrap;
            justify-content: center;
            gap: 15px;
            max-width: 1000px;
            margin: 0 auto;
        }

        /* Each Image */
        .photo {
            width: 250px;
            height: 250px;
            border: 5px solid white;
            cursor: pointer;
            object-fit: cover; /* Keeps the image square */
        }

        .photo:hover {
            border-color: yellow; /* Simple highlight */
        }

        /* The Lightbox (Hidden by default) */
        #photo-modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(0,0,0,0.8); /* See-through black */
            text-align: center;
        }

        /* The Big Image inside the Lightbox */
        #full-photo {
            margin-top: 50px;
            max-width: 90%;
            max-height: 80%;
            border: 10px solid white;
        }

        /* Close Button */
        .close-btn {
            color: white;
            font-size: 50px;
            font-weight: bold;
            cursor: pointer;
            position: absolute;
            top: 10px;
            right: 30px;
        }
    </style>
</head>
<body>

    <h1>My Photo Gallery</h1>
    <p>Click on any photo to see it bigger!</p>

    <div class="gallery">
        <!-- 9 Sample Images -->
        <img class="photo" src="https://picsum.photos/id/10/400/400" onclick="showImage(this.src)">
        <img class="photo" src="https://picsum.photos/id/20/400/400" onclick="showImage(this.src)">
        <img class="photo" src="https://picsum.photos/id/30/400/400" onclick="showImage(this.src)">
        <img class="photo" src="https://picsum.photos/id/40/400/400" onclick="showImage(this.src)">
        <img class="photo" src="https://picsum.photos/id/50/400/400" onclick="showImage(this.src)">
        <img class="photo" src="https://picsum.photos/id/60/400/400" onclick="showImage(this.src)">
        <img class="photo" src="https://picsum.photos/id/70/400/400" onclick="showImage(this.src)">
        <img class="photo" src="https://picsum.photos/id/80/400/400" onclick="showImage(this.src)">
        <img class="photo" src="https://picsum.photos/id/90/400/400" onclick="showImage(this.src)">
    </div>

    <!-- The Modal Lightbox -->
    <div id="photo-modal">
        <span class="close-btn" onclick="hideImage()">&times;</span>
        <img id="full-photo" src="">
    </div>

    <script>
        // Function to show the image
        function showImage(imagePath) {
            var modal = document.getElementById("photo-modal");
            var fullImg = document.getElementById("full-photo");
            
            fullImg.src = imagePath; // Set the big image source
            modal.style.display = "block"; // Show the modal
        }

        // Function to hide the image
        function hideImage() {
            var modal = document.getElementById("photo-modal");
            modal.style.display = "none"; // Hide the modal
        }
    </script>

</body>
</html>